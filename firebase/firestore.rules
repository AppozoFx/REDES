rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Lee roles desde usuarios_access/{uid}
    function accessDoc(uid) {
      return get(/databases/$(database)/documents/usuarios_access/$(uid));
    }

    function isAdmin() {
      return signedIn()
        && accessDoc(request.auth.uid).data.estadoAcceso == "HABILITADO"
        && accessDoc(request.auth.uid).data.roles.hasAny(["ADMIN"]);
    }

    // Reglas generales: no permitir deletes desde cliente
    function denyDeletes() {
      return false;
    }

    /* =========================
       USUARIOS (perfil)
       ========================= */
    match /usuarios/{uid} {
      // Lectura: dueño o admin
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      // Listado: solo admin
      allow list: if isAdmin();

      // Escrituras: solo admin escribe perfiles
      allow create, update: if isAdmin();

      // No delete: siempre soft delete vía estado/audit
      allow delete: if denyDeletes();
    }

    /* =========================
       USUARIOS_ACCESS (accesos)
       ========================= */
    match /usuarios_access/{uid} {
      // Lectura: dueño o admin
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      // Listado: solo admin
      allow list: if isAdmin();

      // Solo admin modifica accesos
      allow create, update: if isAdmin();

      // No delete
      allow delete: if denyDeletes();
    }

    /* =========================
       MODULOS (catálogo)
       ========================= */
    match /modulos/{modId} {
      // Todos los autenticados pueden leer (para construir menú/UI)
      allow get, list: if signedIn();

      // Solo admin crea/actualiza
      allow create, update: if isAdmin();

      // No delete
      allow delete: if denyDeletes();
    }

    /* =========================
       ROLES (plantillas)
       ========================= */
    match /roles/{roleId} {
      // Lectura para usuarios autenticados (para permisos/UI)
      allow get, list: if signedIn();

      // Solo admin crea/actualiza
      allow create, update: if isAdmin();

      // No delete
      allow delete: if denyDeletes();
    }

    /* =========================
       AUDITORIA (bitácora)
       ========================= */
    match /auditoria/{docId} {
      // Solo admin lee auditoría
      allow get, list: if isAdmin();

      // Cliente no escribe auditoría (solo servidor con Admin SDK)
      allow create, update, delete: if false;
    }

    /* =========================
       NOTIFICACIONES (lectura global)
       ========================= */
    match /notificaciones/{id} {
      // Todos los autenticados pueden leer
      allow get, list: if signedIn();
      // Cliente NO escribe notificaciones (solo Admin SDK del servidor)
      allow create, update, delete: if false;
    }

    /* =========================
       NOTIFICACIONES_READS (lecturas y escrituras propias)
       ========================= */
    match /notificaciones_reads/{rid} {
      // Solo el dueño puede leer su propio read-flag (rid = `${uid}_${notifId}`)
      allow get: if signedIn() && rid.matches('^' + request.auth.uid + '_.*$');
      // Listar reads está prohibido
      allow list: if false;
      // Crear/actualizar únicamente si el doc pertenece al usuario autenticado
      allow create, update: if signedIn() && rid.matches('^' + request.auth.uid + '_.*$');
      // Delete prohibido
      allow delete: if denyDeletes();
    }

    /* =========================
       DEFAULT: denegar todo lo demás
       ========================= */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

